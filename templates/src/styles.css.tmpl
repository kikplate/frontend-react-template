body {
  margin: 0;
  font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
  background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
  color: #142033;
}

.shell {
  max-width: 680px;
  margin: 56px auto;
  padding: 24px;
  background: #ffffff;
  border-radius: 14px;
  box-shadow: 0 10px 30px rgba(20, 32, 51, 0.12);
}
